BITVAVO_API_KEY=
BITVAVO_API_SECRET=
TRADING_PAIR=BTC-EUR
PAPER_TRADING=true
GRID_LEVELS=10
GRID_ATR_PERIOD=14
GRID_ATR_MULTIPLIER=1.5
ORDER_SIZE_EUR=25
CHECK_INTERVAL_MINUTES=60
# Startbalans voor paper trading. Voor €500 totaal: 250 + 250.
STARTING_BALANCE_EUR=250
# EUR-waarde aan BTC (berekend op live koers bij reset/start). 250 = €250 aan BTC voor 50/50.
STARTING_BALANCE_BTC_EUR=250
MAKER_FEE_PCT=0.15
DASHBOARD_PORT=3001
DASHBOARD_PASSWORD=jouw-wachtwoord-hier
SESSION_SECRET=een-lange-random-string

# Alerts — e-mail en/of webhook.
ALERT_EMAIL=tom_suurling@hotmail.com

# Optie A: Resend (aanbevolen op VPS — gebruikt HTTPS, geen SMTP). Gratis 100/dag.
# Maak account op resend.com, haal API key op. Geen domain verificatie nodig voor testmails.
# RESEND_API_KEY=re_xxxxx

# Optie B: SMTP (Hotmail/Outlook). Sommige VPS-blocken SMTP; dan Resend gebruiken.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=tom_suurling@hotmail.com
SMTP_PASS=jouw-app-wachtwoord

# Optioneel: webhook (Discord, ntfy.sh)
# ALERT_WEBHOOK_URL=
